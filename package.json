{
  "name": "rayzee-monorepo",
  "private": true,
  "version": "4.2.2",
  "type": "module",
  "exports": {
    ".": "./rayzee/src/index.js"
  },
  "peerDependencies": {
    "three": ">=0.170.0",
    "stats-gl": ">=4.0.0"
  },
  "workspaces": [
    "rayzee",
    "app"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "npm -w @rayzee/app run dev",
    "build": "npm -w rayzee run build && npm -w @rayzee/app run build",
    "build:app": "npm -w @rayzee/app run build",
    "build:engine": "npm -w rayzee run build",
    "lint": "eslint .",
    "lint-fix": "npx eslint --fix",
    "preview": "npm -w @rayzee/app run preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "cross-env $(cat .env | xargs) semantic-release --no-ci"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "cross-env": "^7.0.3",
    "eslint": "^9.11.1",
    "eslint-config-mdcs": "^5.0.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.9.0",
    "postcss": "^8.4.47",
    "semantic-release": "^24.2.1",
    "tailwindcss": "^4.0.1",
    "vite": "^7.0.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.24.0",
    "@rollup/rollup-linux-x64-gnu": "4.9.5"
  }
}

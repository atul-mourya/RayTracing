{
  "name": "rayzee",
  "version": "7.9.1",
  "type": "module",
  "description": "Real-time WebGPU path tracing engine built on Three.js",
  "main": "dist/rayzee.umd.js",
  "module": "dist/rayzee.es.js",
  "exports": {
    ".": {
      "import": "./dist/rayzee.es.js",
      "require": "./dist/rayzee.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/atul-mourya/RayTracing.git",
    "directory": "rayzee"
  },
  "keywords": [
    "path-tracing",
    "webgpu",
    "three.js",
    "ray-tracing",
    "renderer"
  ],
  "author": "Atul Mourya",
  "license": "MIT",
  "scripts": {
    "build": "vite build && node scripts/update-size-badge.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "three": ">=0.185.0"
  },
  "optionalDependencies": {
    "oidn-web": ">=0.3.0",
    "onnxruntime-web": ">=1.0.0"
  }
}
